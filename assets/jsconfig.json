{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "checkJs": false,
    "target": "ES2020",
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "strictNullChecks": true,
    "types": ["./global.d.ts", "./standard-events.d.ts"],
    "paths": {
      "@theme/*": ["./*"],
      "@shopify/events": ["./standard-events"]
    }
  },
  "exclude": [
        "node_modules"
  ]
}
