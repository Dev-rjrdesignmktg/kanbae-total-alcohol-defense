        "testimonial_9pHwnq": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "title": "Great! Good for heavy flushers",
            "body": "Works very well at reducing flush and mitigating hangover! However, for heavy drinking sessions, flush remains. I do feel that the optimal duration to eat is about 20min before drinking for me~ also love the small packets so that I can pack them easily in my pouch",
            "author": "W*****2",
            "date": "3 May 2025",
            "product": "Kanbae Total Alcohol Defense"
          }
        },
        "testimonial_rtjdbE": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "title": "great really works!",
            "body": "Multiple repurchase!! I always take one right before bed after heavy drinking and I always wake up way more refreshed with no pounding headache the next day. Can't be without this now. I always have back ups.",
            "author": "I*****r",
            "date": "22 Mar 2023",
