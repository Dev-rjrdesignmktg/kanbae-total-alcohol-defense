            "description": "<p>Supplies the raw material your liver needs to keep regenerating glutathione throughout the night.</p>",
            "badge_text": "Protect Liver, Antioxidants & Nutrients"
          }
        },
        "ingredient_yk7Ac3": {
          "type": "ingredient",
          "settings": {
            "name": "S-Acetyl Glutathione",
            "description": "<p>Highly bioavailable (and expensive) form of your body's master antioxidant, directly neutralizes acetaldehyde via a second pathway.</p>",
            "badge_text": "Clear Acetaldehyde, Protect Liver, Antioxidants & Nutrients"
          }
        },
        "ingredient_mGFtKc": {
          "type": "ingredient",
          "settings": {
            "name": "Succinic Acid",
            "description": "<p>Keeps liver cells energized during detox by bypassing the metabolic blockage alcohol creates in mitochondria.</p>",
            "badge_text": "Clear Acetaldehyde, Protect Liver"
          }
        },
        "ingredient_Pad9Ha": {
          "type": "ingredient",
          "settings": {
            "name": "Ginger Extract",
            "description": "<p>Minimizes nausea while reducing neuroinflammation for faster cognitive recovery.</p>",
