    "section_gCwKt7": {
      "type": "section",
      "blocks": {
        "text_PyDapn": {
          "type": "text",
          "name": "t:names.heading",
          "settings": {
            "text": "<h2>Frequently asked questions</h2>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "left",
            "type_preset": "h3",
