          }
        },
        "ingredient_zEanHq": {
          "type": "ingredient",
          "settings": {
            "name": "Vitamin B1 (Thiamine)",
            "description": "<p>Restores the mitochondrial cofactor alcohol depletes - critical for your liver's ability to fully process its byproducts.</p>",
            "badge_text": "Clear Acetaldehyde, Protect Liver, Antioxidants & Nutrients"
          }
        },
        "ingredient_MbQV9D": {
          "type": "ingredient",
          "settings": {
            "name": "Vitamin B6 (Pyridoxal-5'-Phospate)",
            "description": "<p>Replenishes B6, which is degraded by acetaldehyde. Responsible for serotonin, GABA, and dopamine production - the biochemical drivers of sleep and next-day mood.</p>",
            "badge_text": "Antioxidants & Nutrients, Brain & Mood, Digestive Support"
          }
        },
        "ingredient_mYrM78": {
          "type": "ingredient",
          "settings": {
