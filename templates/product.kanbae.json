                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_QMTtxw": {
                      "type": "text",
                      "settings": {
                        "text": "<p><strong>Serving size: </strong>2 capsules</p><p><strong>One box contains:</strong> 6 servings</p><p><strong>How many to order?</strong></p><ul><li>1-2 drinks per month = 1 box / 3 months</li><li>1-2 drinks per week = 3 box / 3 months</li><li>3-4 drinks per week = 6 box / 3 months</li></ul>",
