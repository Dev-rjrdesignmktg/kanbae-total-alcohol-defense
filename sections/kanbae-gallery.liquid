{{ "kanbae-gallery.css" | asset_url | stylesheet_tag }}
<script src="{{ 'kanbae-gallery.js' | asset_url }}" defer="defer"></script>

<section class="kanbae-gallery" aria-label="{{ section.settings.headline | default: 'Kanbae gallery' | escape }}">
  <div class="kanbae-gallery__inner">
    {%- if section.settings.eyebrow != blank or section.settings.headline != blank -%}
      <div class="kanbae-gallery__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="kanbae-gallery__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.headline != blank -%}
          <h2 class="kanbae-gallery__headline">{{ section.settings.headline | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kanbae-gallery__viewport">
      <div class="kanbae-gallery__track" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign media_type = block.settings.media_type
            case media_type
              when 'product'
                assign fallback_alt = 'Kanbae product shot'
                assign type_label = 'Product'
              when 'lifestyle'
                assign fallback_alt = 'Kanbae lifestyle photography'
                assign type_label = 'Lifestyle'
              when 'ingredients'
                assign fallback_alt = 'Kanbae ingredients close-up'
                assign type_label = 'Ingredients'
              when 'how_to'
                assign fallback_alt = 'How to use Kanbae'
                assign type_label = 'How-to'
              when 'ugc'
                assign fallback_alt = 'Kanbae customer photo'
                assign type_label = 'UGC'
              when 'review'
                assign fallback_alt = 'Kanbae customer review'
                assign type_label = 'Review'
            endcase
            assign img_alt = block.settings.image.alt | default: fallback_alt
          -%}
          <div class="kanbae-gallery__slide" role="listitem" data-media-type="{{ media_type }}" {{ block.shopify_attributes }}>
            <span class="kanbae-gallery__tag">{{ type_label }}</span>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1600 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 1200px) 50vw, 100vw',
                widths: '480, 750, 960, 1200, 1600',
                class: 'kanbae-gallery__image',
                alt: img_alt
              }}
            {%- else -%}
              <div class="kanbae-gallery__placeholder" role="img" aria-label="{{ img_alt }}"></div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="kanbae-gallery__controls">
        <button class="kanbae-gallery__arrow kanbae-gallery__arrow--prev" type="button" aria-label="Previous media">&#8592;</button>
        <div class="kanbae-gallery__dots">
          {%- for block in section.blocks -%}
            <button class="kanbae-gallery__dot {% if forloop.first %}is-active{% endif %}" type="button" aria-label="Go to slide {{ forloop.index }}" data-slide="{{ forloop.index0 }}"></button>
          {%- endfor -%}
        </div>
        <button class="kanbae-gallery__arrow kanbae-gallery__arrow--next" type="button" aria-label="Next media">&#8594;</button>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gallery Carousel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "See Kanbae in Action" }
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Media",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "product", "label": "Product" },
            { "value": "lifestyle", "label": "Lifestyle" },
            { "value": "ingredients", "label": "Ingredients" },
            { "value": "how_to", "label": "How-to" },
            { "value": "ugc", "label": "UGC" },
            { "value": "review", "label": "Review" }
          ],
          "default": "product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery Carousel",
      "blocks": [
        { "type": "media", "settings": { "media_type": "product" } },
        { "type": "media", "settings": { "media_type": "lifestyle" } },
        { "type": "media", "settings": { "media_type": "ingredients" } },
        { "type": "media", "settings": { "media_type": "how_to" } },
        { "type": "media", "settings": { "media_type": "ugc" } },
        { "type": "media", "settings": { "media_type": "review" } }
      ]
    }
  ]
}
{% endschema %}
