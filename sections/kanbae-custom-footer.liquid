{{ "kanbae-custom-footer.css" | asset_url | stylesheet_tag }}

{%- liquid
  assign kcf_id = section.id
  assign kcf_bg = section.settings.background_color
  assign kcf_text = section.settings.text_color
  assign kcf_accent = section.settings.accent_color
  assign kcf_border = section.settings.border_color
  assign logo_alt = section.settings.logo_image.alt | default: shop.name
  assign logo_style = 'width:' | append: section.settings.logo_width | append: 'px;'
-%}

<section
  class="kanbae-custom-footer"
  id="kanbae-custom-footer-{{ kcf_id }}"
  style="
    --kcf-bg: {{ kcf_bg }};
    --kcf-text: {{ kcf_text }};
    --kcf-accent: {{ kcf_accent }};
    --kcf-border: {{ kcf_border }};
    --kcf-padding-top: {{ section.settings.padding_top }}px;
    --kcf-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="kanbae-custom-footer__container">
    <div class="kanbae-custom-footer__grid">

      {%- comment -%} Column 1 — Brand + Newsletter {%- endcomment -%}
      <div class="kanbae-custom-footer__col kanbae-custom-footer__col--brand">
        {%- if section.settings.logo_image != blank -%}
          {{ section.settings.logo_image | image_url: width: 400 | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 990px) 160px, 140px',
            widths: '80, 160, 240, 320, 400',
            class: 'kanbae-custom-footer__logo',
            alt: logo_alt,
            style: logo_style
          }}
        {%- else -%}
          <p class="kanbae-custom-footer__logo-text">{{ shop.name }}</p>
        {%- endif -%}

        {%- if section.settings.brand_promise != blank -%}
          <div class="kanbae-custom-footer__promise">{{ section.settings.brand_promise }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="kanbae-custom-footer__socials" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'social_icon' and block.settings.url != blank -%}
                <li class="kanbae-custom-footer__social-item" {{ block.shopify_attributes }}>
                  <a
                    href="{{ block.settings.url }}"
                    class="kanbae-custom-footer__social-link"
                    aria-label="{{ block.settings.label | default: block.settings.icon | capitalize }}"
                    target="_blank"
                    rel="noopener"
                  >
                    <svg width="18" height="18" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">{%- render 'icon', icon: block.settings.icon -%}</svg>
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} Column 2 — Newsletter signup {%- endcomment -%}
      <div class="kanbae-custom-footer__col kanbae-custom-footer__col--newsletter">
        {%- if section.settings.newsletter_heading != blank -%}
          <h2 class="kanbae-custom-footer__title">{{ section.settings.newsletter_heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.newsletter_subtext != blank -%}
          <p class="kanbae-custom-footer__subtext">{{ section.settings.newsletter_subtext | escape }}</p>
        {%- endif -%}

        {%- form 'customer', class: 'kanbae-custom-footer__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <div
              class="kanbae-custom-footer__message kanbae-custom-footer__message--success"
              id="KanbaeFooterNewsletterSuccess-{{ kcf_id }}"
              tabindex="-1"
            >
              {{ section.settings.success_message | escape }}
            </div>
          {%- else -%}
            <div class="kanbae-custom-footer__field-group">
              <label for="KanbaeFooterEmail-{{ kcf_id }}" class="kanbae-custom-footer__visually-hidden">
                {{ section.settings.input_label | escape }}
              </label>
              <input
                id="KanbaeFooterEmail-{{ kcf_id }}"
                type="email"
                name="contact[email]"
                class="kanbae-custom-footer__input"
                value="{{ form.email }}"
                placeholder="{{ section.settings.input_placeholder | escape }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                inputmode="email"
                required
                aria-required="true"
                {%- if form.errors %}
                  aria-invalid="true"
                  aria-describedby="KanbaeFooterError-{{ kcf_id }}"
                {%- endif %}
              >
              <button
                type="submit"
                class="kanbae-custom-footer__button"
                name="commit"
                aria-label="{{ section.settings.button_label | escape }}"
              >
                {{ section.settings.button_label | escape }}
              </button>
            </div>

            {%- if form.errors -%}
              <div class="kanbae-custom-footer__message kanbae-custom-footer__message--error" id="KanbaeFooterError-{{ kcf_id }}">
                {%- for field in form.errors -%}
                  {%- if field == 'form' -%}
                    {{ form.errors.messages[field] }}
                  {%- else -%}
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}.
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}

        {%- if section.blocks.size > 0 -%}
          <div class="kanbae-custom-footer__extra-buttons">
            {%- for block in section.blocks -%}
              {%- if block.type == 'newsletter_button' and block.settings.label != blank -%}
                <a
                  href="{{ block.settings.url | default: '#' }}"
                  class="kanbae-custom-footer__extra-button kanbae-custom-footer__extra-button--{{ block.settings.style }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.label | escape }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Column 3 — Learn {%- endcomment -%}
      <nav class="kanbae-custom-footer__col kanbae-custom-footer__col--menu" aria-label="{{ section.settings.learn_title | default: 'Learn' | escape }}">
        {%- if section.settings.learn_title != blank -%}
          <h3 class="kanbae-custom-footer__menu-title">{{ section.settings.learn_title | escape }}</h3>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="kanbae-custom-footer__menu-list" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'learn_link' and block.settings.label != blank -%}
                <li class="kanbae-custom-footer__menu-item" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.url | default: '#' }}" class="kanbae-custom-footer__menu-link">
                    {{ block.settings.label | escape }}
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </nav>

      {%- comment -%} Column 4 — Support {%- endcomment -%}
      <nav class="kanbae-custom-footer__col kanbae-custom-footer__col--menu" aria-label="{{ section.settings.support_title | default: 'Support' | escape }}">
        {%- if section.settings.support_title != blank -%}
          <h3 class="kanbae-custom-footer__menu-title">{{ section.settings.support_title | escape }}</h3>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="kanbae-custom-footer__menu-list" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'support_link' and block.settings.label != blank -%}
                <li class="kanbae-custom-footer__menu-item" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.url | default: '#' }}" class="kanbae-custom-footer__menu-link">
                    {{ block.settings.label | escape }}
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </nav>

    </div>

    {%- comment -%} Bottom bar — payment icons + copyright + extra tags {%- endcomment -%}
    <div class="kanbae-custom-footer__bottom">
      {%- if section.settings.show_payment_icons -%}
        <ul class="kanbae-custom-footer__payment" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li class="kanbae-custom-footer__payment-item">
              {{ type | payment_type_svg_tag: class: 'kanbae-custom-footer__payment-icon' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <p class="kanbae-custom-footer__copyright">{{ section.settings.copyright_text }}</p>

      {%- if section.blocks.size > 0 -%}
        <ul class="kanbae-custom-footer__bottom-tags" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bottom_tag' and block.settings.label != blank -%}
              <li class="kanbae-custom-footer__bottom-tag" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != 'none' -%}
                  <svg width="14" height="14" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">{%- render 'icon', icon: block.settings.icon -%}</svg>
                {%- endif -%}
                {%- if block.settings.url != blank -%}
                  <a href="{{ block.settings.url }}" class="kanbae-custom-footer__bottom-tag-link">{{ block.settings.label | escape }}</a>
                {%- else -%}
                  <span>{{ block.settings.label | escape }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kanbae Custom Footer",
  "tag": "section",
  "class": "section kanbae-custom-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Brand (Column 1)"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 140
    },
    {
      "type": "richtext",
      "id": "brand_promise",
      "label": "Brand promise text",
      "default": "<p>Become a Kanbae today.<br>Recovery built for the nights.</p>"
    },
    {
      "type": "header",
      "content": "Newsletter (Column 2)"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Subtext",
      "default": "Recovery tips, drops, and offers — straight to your inbox."
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "Email field label (screen readers only)",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Email field placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Sign up"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in. Welcome to the ritual."
    },
    {
      "type": "header",
      "content": "Menus (Columns 3 & 4)"
    },
    {
      "type": "text",
      "id": "learn_title",
      "label": "Column 3 title",
      "default": "Learn"
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Column 4 title",
      "default": "Support"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "info": "Pulled natively from your Shopify payment settings.",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 KANBAE. All rights reserved."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F7F6F2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0A1915"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (button / links hover)",
      "default": "#A3FF16"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Divider / border color",
      "default": "#0A191533"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "social_icon",
      "name": "Social icon",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "instagram", "label": "Instagram" },
            { "value": "tiktok", "label": "TikTok" },
            { "value": "facebook", "label": "Facebook" },
            { "value": "x", "label": "X (Twitter)" },
            { "value": "youtube", "label": "YouTube" },
            { "value": "pinterest", "label": "Pinterest" },
            { "value": "tumblr", "label": "Tumblr" }
          ],
          "default": "instagram"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Accessible label",
          "info": "Used for screen readers. Defaults to the icon name.",
          "default": "Instagram"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    },
    {
      "type": "newsletter_button",
      "name": "Extra button (Column 2)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "outline", "label": "Outline" }
          ],
          "default": "outline"
        }
      ]
    },
    {
      "type": "learn_link",
      "name": "Learn link (Column 3)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Ingredients"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    },
    {
      "type": "support_link",
      "name": "Support link (Column 4)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Contact"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    },
    {
      "type": "bottom_tag",
      "name": "Bottom bar tag",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Privacy Policy"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon (optional)",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "lock", "label": "Lock" },
            { "value": "check_box", "label": "Checkmark" },
            { "value": "leaf", "label": "Leaf" }
          ],
          "default": "none"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kanbae Custom Footer",
      "blocks": [
        { "type": "social_icon", "settings": { "icon": "instagram", "label": "Instagram" } },
        { "type": "social_icon", "settings": { "icon": "tiktok", "label": "TikTok" } },
        { "type": "learn_link", "settings": { "label": "Ingredients" } },
        { "type": "learn_link", "settings": { "label": "How it Works" } },
        { "type": "learn_link", "settings": { "label": "FAQ" } },
        { "type": "learn_link", "settings": { "label": "Reviews" } },
        { "type": "support_link", "settings": { "label": "Contact" } },
        { "type": "support_link", "settings": { "label": "Returns" } },
        { "type": "support_link", "settings": { "label": "Shipping" } },
        { "type": "support_link", "settings": { "label": "Privacy Policy" } }
      ]
    }
  ]
}
{% endschema %}
