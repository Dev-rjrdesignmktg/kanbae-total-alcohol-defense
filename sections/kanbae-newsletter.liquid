{{ "kanbae-newsletter.css" | asset_url | stylesheet_tag }}

{%- liquid
  assign kn_id = section.id
  assign kn_bg = section.settings.background_color
  assign kn_text = section.settings.text_color
  assign kn_accent = section.settings.accent_color
-%}

<section
  class="kanbae-newsletter"
  id="kanbae-newsletter-{{ kn_id }}"
  style="
    --kn-bg: {{ kn_bg }};
    --kn-text: {{ kn_text }};
    --kn-accent: {{ kn_accent }};
    --kn-padding-top: {{ section.settings.padding_top }}px;
    --kn-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="kanbae-newsletter__container">

    {%- if section.settings.eyebrow != blank -%}
      <p class="kanbae-newsletter__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.headline != blank -%}
      <h2 class="kanbae-newsletter__headline">{{ section.settings.headline | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subheadline != blank -%}
      <p class="kanbae-newsletter__subheadline">{{ section.settings.subheadline | escape }}</p>
    {%- endif -%}

    {%- if section.settings.social_proof != blank -%}
      <p class="kanbae-newsletter__social-proof">{{ section.settings.social_proof | escape }}</p>
    {%- endif -%}

    <div class="kanbae-newsletter__form-wrap">
    {%- form 'customer', class: 'kanbae-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}

          <div
            class="kanbae-newsletter__message kanbae-newsletter__message--success"
            id="KanbaeNewsletterSuccess-{{ kn_id }}"
            tabindex="-1"
          >
            {{ section.settings.success_message | escape }}
          </div>

        {%- else -%}

          <div class="kanbae-newsletter__field-group">
            <label for="KanbaeNewsletterEmail-{{ kn_id }}" class="kanbae-newsletter__visually-hidden">
              {{ section.settings.input_label | escape }}
            </label>
            <input
              id="KanbaeNewsletterEmail-{{ kn_id }}"
              type="email"
              name="contact[email]"
              class="kanbae-newsletter__input"
              value="{{ form.email }}"
              placeholder="{{ section.settings.input_placeholder | escape }}"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              inputmode="email"
              required
              aria-required="true"
              {%- if form.errors %}
                aria-invalid="true"
                aria-describedby="KanbaeNewsletterError-{{ kn_id }}"
              {%- endif %}
            >
            <button
              type="submit"
              class="kanbae-newsletter__button"
              name="commit"
              aria-label="{{ section.settings.button_label | escape }}"
            >
              {{ section.settings.button_label | escape }}
            </button>
          </div>

          {%- if form.errors -%}
            <div
              class="kanbae-newsletter__message kanbae-newsletter__message--error"
              id="KanbaeNewsletterError-{{ kn_id }}"
            >
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}.
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

        {%- endif -%}

      {%- endform -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Kanbae Newsletter",
  "tag": "section",
  "class": "section kanbae-newsletter-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Join the Ritual"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Better nights start here."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Get recovery tips, exclusive drops, and subscriber-only offers."
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Social proof line",
      "default": "Join 25,000+ people building better mornings."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "Email field label (screen readers only)",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Email field placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join Us"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in. Welcome to the ritual."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F7F4EE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#23291F"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (button / eyebrow)",
      "default": "#2F4A3D"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "Kanbae Newsletter",
      "category": "Email signup"
    }
  ]
}
{% endschema %}