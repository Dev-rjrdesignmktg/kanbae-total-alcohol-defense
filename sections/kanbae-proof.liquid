{{ "kanbae-proof.css" | asset_url | stylesheet_tag }}
<script src="{{ 'kanbae-proof.js' | asset_url }}" defer="defer"></script>

<section class="kanbae-proof" aria-label="{{ section.settings.headline | default: 'Scientific proof' | escape }}" data-section-id="{{ section.id }}">
  <div class="kanbae-proof__inner">

    <div class="kanbae-proof__media">
      <div class="kanbae-proof__stage">
        {%- for block in section.blocks -%}
          {%- liquid
            assign img_alt = block.settings.image.alt | default: block.settings.title | default: 'Kanbae scientific evidence'
          -%}
          <div class="kanbae-proof__slide{% if forloop.first %} is-active{% endif %}" data-proof-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1400 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 960px) 46vw, 100vw',
                widths: '480, 750, 960, 1200, 1400',
                class: 'kanbae-proof__image',
                alt: img_alt
              }}
            {%- else -%}
              <div class="kanbae-proof__placeholder" role="img" aria-label="{{ img_alt }}"></div>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if section.blocks.size > 1 -%}
          <button class="kanbae-proof__chevron kanbae-proof__chevron--prev" type="button" aria-label="Previous slide">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="kanbae-proof__chevron kanbae-proof__chevron--next" type="button" aria-label="Next slide">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="kanbae-proof__indicators" role="tablist" aria-label="Scientific proof slides">
          {%- for block in section.blocks -%}
            <button class="kanbae-proof__indicator{% if forloop.first %} is-active{% endif %}" type="button" role="tab" aria-label="Go to slide {{ forloop.index }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" data-proof-goto="{{ forloop.index0 }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="kanbae-proof__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="kanbae-proof__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.headline != blank -%}
        <h2 class="kanbae-proof__headline">{{ section.settings.headline | escape }}</h2>
      {%- endif -%}

      <div class="kanbae-proof__panels">
        {%- for block in section.blocks -%}
          <div class="kanbae-proof__panel{% if forloop.first %} is-active{% endif %}" data-proof-panel="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="kanbae-proof__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <div class="kanbae-proof__description">{{ block.settings.description | newline_to_br }}</div>
            {%- endif -%}
            {%- if block.settings.metric != blank -%}
              <p class="kanbae-proof__metric"><span class="kanbae-proof__metric-dot"></span>{{ block.settings.metric | escape }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Scientific Proof Carousel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Clinical Evidence" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "The Science Behind Kanbae" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Graph / image" },
        { "type": "text", "id": "title", "label": "Benefit title", "default": "Boost Your Alcohol Metabolism" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Clinical data shows accelerated breakdown of acetaldehyde, reducing oxidative stress on the liver." },
        { "type": "text", "id": "metric", "label": "Key metric", "default": "2x increase" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scientific Proof Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
