            "author": "Diego M.",
            "date": "Hace 1 mes",
            "product": "Kanbae Total Alcohol Defense"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 4,
            "title": "Funciona de verdad",
            "body": "Era escéptica, pero después de un fin de semana de bodas sin resaca me convertí en fan.",
            "author": "Valentina S.",
            "date": "Hace 2 meses",
            "product": "Kanbae Total Alcohol Defense"
          }
        }
      ]
    }
  ]
}
{% endschema %}
