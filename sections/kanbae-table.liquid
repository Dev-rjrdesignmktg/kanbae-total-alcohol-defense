
{{ "kanbae-table.css" | asset_url | stylesheet_tag }}
<script src="{{ 'kanbae-table.js' | asset_url }}" defer></script>

{%- liquid
  assign kanbae_label = section.settings.kanbae_label
  assign typical_label = section.settings.typical_label
  assign traditional_label = section.settings.traditional_label
-%}

<section
  class="kanbae-table-section"
  id="kanbae-table-{{ section.id }}"
  style="--kt-padding-top: {{ section.settings.padding_top }}px; --kt-padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-kanbae-table
  {% if section.settings.enable_animation %}data-animate="true"{% endif %}
>
  <div class="kanbae-table__container">

    {%- if section.settings.eyebrow != blank
       or section.settings.heading != blank
       or section.settings.subheading != blank -%}
      <div class="kanbae-table__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="kanbae-table__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kanbae-table__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="kanbae-table__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="kanbae-table__scroll">
        <table class="kanbae-table__table">
          <caption class="visually-hidden">
            {{ section.settings.heading | default: 'Kanbae comparison table' }}
          </caption>
          <thead>
            <tr class="kanbae-table__row kanbae-table__row--head">
              <th scope="col" class="kanbae-table__cell kanbae-table__cell--benefit">
                <span class="visually-hidden">Benefit</span>
              </th>
              <th scope="col" class="kanbae-table__cell kanbae-table__cell--kanbae">
                {%- if section.settings.kanbae_badge_text != blank -%}
                  <span class="kanbae-table__badge">{{ section.settings.kanbae_badge_text }}</span>
                {%- endif -%}
                <span class="kanbae-table__col-title">{{ kanbae_label }}</span>
              </th>
              <th scope="col" class="kanbae-table__cell kanbae-table__cell--typical">
                <span class="kanbae-table__col-title">{{ typical_label }}</span>
              </th>
              <th scope="col" class="kanbae-table__cell kanbae-table__cell--traditional">
                <span class="kanbae-table__col-title">{{ traditional_label }}</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                {%- liquid
                  assign benefit = block.settings.benefit
                  assign kanbae_status = block.settings.kanbae_status
                  assign kanbae_note = block.settings.kanbae_note
                  assign typical_status = block.settings.typical_status
                  assign typical_note = block.settings.typical_note
                  assign traditional_status = block.settings.traditional_status
                  assign traditional_note = block.settings.traditional_note
                -%}
                <tr
                  class="kanbae-table__row"
                  style="--kt-row-index: {{ forloop.index0 }};"
                  {{ block.shopify_attributes }}
                >
                  <th scope="row" class="kanbae-table__cell kanbae-table__cell--benefit">
                    {{ benefit }}
                  </th>

                  <td class="kanbae-table__cell kanbae-table__cell--kanbae" data-label="{{ kanbae_label }}">
                    <span class="kanbae-table__status kanbae-table__status--{{ kanbae_status }}">
                      {%- if kanbae_status == 'check' -%}
                        {%- render 'icon-check', size: 21, class: 'kanbae-table__icon' -%}
                      {%- else -%}
                        {%- render 'icon-cross', size: 21, class: 'kanbae-table__icon' -%}
                      {%- endif -%}
                      {%- if kanbae_note != blank -%}
                        <span class="kanbae-table__note">{{ kanbae_note }}</span>
                      {%- endif -%}
                    </span>
                  </td>

                  <td class="kanbae-table__cell kanbae-table__cell--typical" data-label="{{ typical_label }}">
                    <span class="kanbae-table__status kanbae-table__status--{{ typical_status }}">
                      {%- if typical_status == 'check' -%}
                        {%- render 'icon-check', size: 21, class: 'kanbae-table__icon' -%}
                      {%- else -%}
                        {%- render 'icon-cross', size: 21, class: 'kanbae-table__icon' -%}
                      {%- endif -%}
                      {%- if typical_note != blank -%}
                        <span class="kanbae-table__note">{{ typical_note }}</span>
                      {%- endif -%}
                    </span>
                  </td>

                  <td class="kanbae-table__cell kanbae-table__cell--traditional" data-label="{{ traditional_label }}">
                    <span class="kanbae-table__status kanbae-table__status--{{ traditional_status }}">
                      {%- if traditional_status == 'check' -%}
                        {%- render 'icon-check', size: 21, class: 'kanbae-table__icon' -%}
                      {%- else -%}
                        {%- render 'icon-cross', size: 21, class: 'kanbae-table__icon' -%}
                      {%- endif -%}
                      {%- if traditional_note != blank -%}
                        <span class="kanbae-table__note">{{ traditional_note }}</span>
                      {%- endif -%}
                    </span>
                  </td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- else -%}
      <div class="kanbae-table__empty">
       <span>Add "Benefit row" blocks to build your comparison table.</span>
      </div>
    {%- endif -%}

  </div>
</section>



{% schema %}
{
  "name": "Kanbae Comparison Table",
  "tag": "section",
  "class": "kanbae-table-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Why Kanbae"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The clear choice for your wellness"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "See how Kanbae compares to typical supplements and traditional remedies."
    },
    {
      "type": "header",
      "content": "Columns"
    },
    {
      "type": "text",
      "id": "kanbae_label",
      "label": "Kanbae column label",
      "default": "Kanbae"
    },
    {
      "type": "text",
      "id": "kanbae_badge_text",
      "label": "Kanbae badge (optional)",
      "info": "Small pill shown above the Kanbae column, e.g. \"Best Choice\". Leave blank to hide.",
      "default": "Best Choice"
    },
    {
      "type": "text",
      "id": "typical_label",
      "label": "Typical Supplements column label",
      "default": "Typical Supplements"
    },
    {
      "type": "text",
      "id": "traditional_label",
      "label": "Traditional Remedies column label",
      "default": "Traditional Remedies"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable scroll-in animation",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Benefit row",
      "settings": [
        {
          "type": "text",
          "id": "benefit",
          "label": "Benefit",
          "default": "Bioavailability"
        },
        {
          "type": "header",
          "content": "Kanbae"
        },
        {
          "type": "select",
          "id": "kanbae_status",
          "label": "Status",
          "default": "check",
          "options": [
            { "value": "check", "label": "Check (yes)" },
            { "value": "cross", "label": "Cross (no)" }
          ]
        },
        {
          "type": "text",
          "id": "kanbae_note",
          "label": "Note (optional)",
          "info": "Short caption shown under the icon, e.g. \"Optimized absorption\""
        },
        {
          "type": "header",
          "content": "Typical Supplements"
        },
        {
          "type": "select",
          "id": "typical_status",
          "label": "Status",
          "default": "cross",
          "options": [
            { "value": "check", "label": "Check (yes)" },
            { "value": "cross", "label": "Cross (no)" }
          ]
        },
        {
          "type": "text",
          "id": "typical_note",
          "label": "Note (optional)"
        },
        {
          "type": "header",
          "content": "Traditional Remedies"
        },
        {
          "type": "select",
          "id": "traditional_status",
          "label": "Status",
          "default": "cross",
          "options": [
            { "value": "check", "label": "Check (yes)" },
            { "value": "cross", "label": "Cross (no)" }
          ]
        },
        {
          "type": "text",
          "id": "traditional_note",
          "label": "Note (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kanbae Comparison Table",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "benefit": "Bioavailability",
            "kanbae_status": "check",
            "kanbae_note": "Optimized absorption",
            "typical_status": "cross",
            "traditional_status": "cross",
            "traditional_note": "Inconsistent"
          }
        },
        {
          "type": "feature",
          "settings": {
            "benefit": "Third-Party Tested",
            "kanbae_status": "check",
            "typical_status": "cross",
            "traditional_status": "cross"
          }
        },
        {
          "type": "feature",
          "settings": {
            "benefit": "Clinically Dosed",
            "kanbae_status": "check",
            "typical_status": "cross",
            "traditional_status": "cross"
          }
        },
        {
          "type": "feature",
          "settings": {
            "benefit": "No Fillers or Additives",
            "kanbae_status": "check",
            "typical_status": "cross",
            "traditional_status": "cross"
          }
        },
        {
          "type": "feature",
          "settings": {
            "benefit": "Fast-Acting Formula",
            "kanbae_status": "check",
            "typical_status": "cross",
            "traditional_status": "check",
            "traditional_note": "Slow"
          }
        }
      ]
    }
  ]
}
{% endschema %}