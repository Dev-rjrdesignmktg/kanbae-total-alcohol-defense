{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: {{ block.settings.line_active_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    padding-left: {{ block.settings.line_position | plus: 40 }}px;
    padding-bottom: {{ block.settings.item_spacing }}px;
    opacity: 0.4;
    transition: opacity 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 8px;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.background_color }};
    transform: translateX(-50%);
    transition: all 0.5s ease;
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background-color: {{ block.settings.dot_active_color }};
    transform: translateX(-50%) scale(1.3);
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  .ai-timeline-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.description_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: 60px;
    }
  }
{% endstyle %}

<scroll-timeline-{{ ai_gen_id }}
  class="ai-timeline-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
    </div>

    {% if block.settings.item_1_title != blank or block.settings.item_2_title != blank or block.settings.item_3_title != blank or block.settings.item_4_title != blank or block.settings.item_5_title != blank %}
      {% for i in (1..5) %}
        {% liquid
          assign title_key = 'item_' | append: i | append: '_title'
          assign date_key = 'item_' | append: i | append: '_date'
          assign description_key = 'item_' | append: i | append: '_description'

          assign item_title = block.settings[title_key]
          assign item_date = block.settings[date_key]
          assign item_description = block.settings[description_key]
        %}

        {% if item_title != blank %}
          <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
            <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>
            <div class="ai-timeline-content-{{ ai_gen_id }}">
              {% if item_date != blank %}
                <div class="ai-timeline-date-{{ ai_gen_id }}">{{ item_date }}</div>
              {% endif %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ item_title }}</h3>
              {% if item_description != blank %}
                <div class="ai-timeline-description-{{ ai_gen_id }}">{{ item_description }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    {% else %}
      <div class="ai-timeline-empty-{{ ai_gen_id }}">
        Add timeline items to get started
      </div>
    {% endif %}
  </div>
</scroll-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.observer = null;
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        this.progressBar = this.querySelector('.ai-timeline-progress-{{ ai_gen_id }}');

        if (this.items.length === 0) return;

        this.setupIntersectionObserver();
        this.setupScrollListener();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '-50% 0px -50% 0px',
          threshold: 0
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
            } else {
              entry.target.classList.remove('active');
            }
          });
        }, options);

        this.items.forEach((item) => {
          this.observer.observe(item);
        });
      }

      setupScrollListener() {
        const updateProgress = () => {
          if (this.items.length === 0) return;

          const firstItem = this.items[0];
          const lastItem = this.items[this.items.length - 1];

          const firstItemTop = firstItem.getBoundingClientRect().top;
          const lastItemBottom = lastItem.getBoundingClientRect().bottom;
          const viewportHeight = window.innerHeight;

          const timelineStart = firstItemTop + window.scrollY;
          const timelineEnd = lastItemBottom + window.scrollY - viewportHeight;
          const timelineHeight = timelineEnd - timelineStart;

          const scrollPosition = window.scrollY + (viewportHeight / 2);
          const progress = Math.max(0, Math.min(100, ((scrollPosition - timelineStart) / timelineHeight) * 100));

          if (this.progressBar) {
            this.progressBar.style.height = progress + '%';
          }
        };

        window.addEventListener('scroll', updateProgress);
        window.addEventListener('resize', updateProgress);
        updateProgress();
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('scroll-timeline-{{ ai_gen_id }}', ScrollTimeline{{ ai_gen_id }});
  })();
</script>

